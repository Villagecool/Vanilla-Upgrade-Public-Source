{
	"format_version": "1.26.0",
	"minecraft:block": {
		"description": {
			"identifier": "vc:snow_brick_stairs",
			"menu_category": {
				"category": "construction",
				"group": "minecraft:itemGroup.name.stairs"
			},
			"traits": {
				"minecraft:placement_position": {
					"enabled_states": [
						"minecraft:vertical_half"
					]
				},
				"minecraft:placement_direction": {
					"enabled_states": [
						"minecraft:corner_and_cardinal_direction"
					],
					"y_rotation_offset": 180
				}
			}
		},
		"components": {
			"tag:minecraft:is_shovel_item_destructible": {},
			"tag:stairs": {},
			"minecraft:destructible_by_mining": {
				"seconds_to_destroy": 5
			},
			"minecraft:destructible_by_explosion": {
				"explosion_resistance": 0
			},
			"minecraft:light_dampening": 0,
			"minecraft:geometry": {
				"identifier": "geometry.vc.stairs",
				"bone_visibility": {
					"inner_left":  "q.block_state('minecraft:corner') != 'inner_left'",
					"inner_right": "q.block_state('minecraft:corner') != 'inner_right'",
					"outer_left":  "q.block_state('minecraft:corner') == 'outer_left'",
					"outer_right": "q.block_state('minecraft:corner') == 'outer_right'"
					
				}
			},
			"minecraft:material_instances": {
				"*": {
					"texture": "vc_snowbrick",
					"render_method": "alpha_test"
				}
			},
			"minecraft:liquid_detection": {
				"detection_rules": [
					{
						"can_contain_liquid": true,
						"liquid_type": "water",
						"on_liquid_touches": "blocking"
					}
				]
			},
			"minecraft:selection_box": {
				"origin": [
					-8,
					0,
					-8
				],
				"size": [
					16,
					16,
					16
				]
			}
		},
		"permutations": [
			{
				"condition": "query.block_state('minecraft:cardinal_direction') == 'north'",
				"components": {
					"minecraft:transformation": {
						"rotation": [
							0,
							180,
							0
						]
					}
				}
			},
			{
				"condition": "query.block_state('minecraft:cardinal_direction') == 'west'",
				"components": {
					"minecraft:transformation": {
						"rotation": [
							0,
							270,
							0
						]
					}
				}
			},
			{
				"condition": "query.block_state('minecraft:cardinal_direction') == 'east'",
				"components": {
					"minecraft:transformation": {
						"rotation": [
							0,
							90,
							0
						]
					}
				}
			},
			{
				"condition": "q.block_state('minecraft:vertical_half') == 'top'",
				"components": {
					"minecraft:geometry": {
						"identifier": "geometry.vc.stairs_upper",
						"bone_visibility": {
							"inner_left":  "q.block_state('minecraft:corner') != 'inner_left'",
							"inner_right": "q.block_state('minecraft:corner') != 'inner_right'",
							"outer_left":  "q.block_state('minecraft:corner') == 'outer_left'",
							"outer_right": "q.block_state('minecraft:corner') == 'outer_right'"

						}
					}
				}
			},
			{
				"condition": "q.block_state('minecraft:vertical_half') == 'top' && q.block_state('minecraft:corner') == 'inner_right'",
				"components": {
					"minecraft:collision_box": [
						{ "origin": [ -8, 8, -8 ], "size": [ 16, 8, 16] },
						{ "origin": [ -8, 0, -8 ], "size": [ 8, 8, 8] }
					]
				}
			},
			{
				"condition": "q.block_state('minecraft:vertical_half') == 'top' && q.block_state('minecraft:corner') == 'inner_left'",
				"components": {
					"minecraft:collision_box": [
						{ "origin": [ -8, 8, -8 ], "size": [ 16, 8, 16] },
						{ "origin": [ 0, 0, -8 ], "size": [ 8, 8, 8] }
					]
				}
			},
			{
				"condition": "q.block_state('minecraft:vertical_half') == 'top' && q.block_state('minecraft:corner') != 'inner_left' && q.block_state('minecraft:corner') != 'inner_right'",
				"components": {
					"minecraft:collision_box": [
						{ "origin": [ -8, 8, -8 ], "size": [ 16, 8, 16] },
						{ "origin": [ -8, 0, -8 ], "size": [ 16, 8, 8] }
					]
				}
			},
			{
				"condition": "q.block_state('minecraft:vertical_half') == 'bottom' && q.block_state('minecraft:corner') == 'inner_right'",
				"components": {
					"minecraft:collision_box": [
						{ "origin": [ -8, 0, -8 ], "size": [ 16, 8, 16] },
						{ "origin": [ -8, 8, -8 ], "size": [ 8, 8, 8] }
					]
				}
			},
			{
				"condition": "q.block_state('minecraft:vertical_half') == 'bottom' && q.block_state('minecraft:corner') == 'inner_left'",
				"components": {
					"minecraft:collision_box": [
						{ "origin": [ -8, 0, -8 ], "size": [ 16, 8, 16] },
						{ "origin": [ 0, 8, -8 ], "size": [ 8, 8, 8] }
					]
				}
			},
			{
				"condition": "q.block_state('minecraft:vertical_half') == 'bottom' && q.block_state('minecraft:corner') != 'inner_left' && q.block_state('minecraft:corner') != 'inner_right'",
				"components": {
					"minecraft:collision_box": [
						{ "origin": [ -8, 0, -8 ], "size": [ 16, 8, 16] },
						{ "origin": [ -8, 8, -8 ], "size": [ 16, 8, 8] }
					]
				}
			}
		]
	}
}